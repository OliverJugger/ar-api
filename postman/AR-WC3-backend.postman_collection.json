{
  "info": {
    "name": "AR-WC3 Backend",
    "description": "Exemples d'appels pour l'API AR-WC3 Backend (Spring Boot), sécurisée en HTTP Basic Auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{username}}", "type": "string" },
      { "key": "password", "value": "{{password}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (identifiants valides)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Statut 200', () => pm.response.to.have.status(200));",
                  "pm.test('success = true', () => pm.response.json().success === true);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Les identifiants sont envoyés via l'en-tête HTTP Basic (configuré au niveau de la collection/environnement), pas dans le corps de la requête."
          },
          "response": []
        },
        {
          "name": "Login (identifiants invalides -> 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Statut 401', () => pm.response.to.have.status(401));",
                  "pm.test(\"message d'erreur présent\", () => pm.response.json().message !== undefined);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{username}}", "type": "string" },
                { "key": "password", "value": "mauvais-mot-de-passe", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Démontre la réponse 401 (ErrorResponse) renvoyée par le JsonAuthenticationEntryPoint en cas d'échec d'authentification."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Statistics",
      "item": [
        {
          "name": "Récupérer les statistiques du dashboard",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Statut 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('contient stat1..stat4', () => ['stat1','stat2','stat3','stat4'].every(k => Array.isArray(body[k])));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/statistics",
              "host": ["{{baseUrl}}"],
              "path": ["statistics"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "username", "value": "olivier.mignot83" },
    { "key": "password", "value": "password123" }
  ]
}
